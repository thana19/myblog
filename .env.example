# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-32-plus-random-chars

# Database (better-sqlite3)
DB_PATH=./data/myblog.db

# S3-compatible image storage (MinIO defaults below — replace for production R2/S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=myblog-images
S3_PUBLIC_URL_BASE=http://localhost:9000/myblog-images
S3_FORCE_PATH_STYLE=true

# Optional Google Analytics (leave empty to disable)
GA_ID=
